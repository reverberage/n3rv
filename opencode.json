{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "nerv",
  "instructions": [
    "AGENTS.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "docs/*.md"
  ],
  "plugins": [
    ".opencode/plugins/nerv-lifecycle.js",
    ".opencode/plugins/nerv-shell-env.js"
  ],
  "tools": {
    "websearch": { "disable": false }
  },
  "agent": {
    "build": { "disable": true },
    "plan": { "disable": true }
  },
  "mcp": {
    "nerv-memory": {
      "type": "local",
      "command": ["uv", "run", "nerv-memory"],
      "env": {"NERV_AGENT_SOURCE": "opencode"}
    },
    "nerv-hub": {
      "type": "local",
      "command": ["uv", "run", "nerv-hub"],
      "env": {"NERV_AGENT_SOURCE": "opencode"}
    }
  }
}